      "tourist_visa_l": {
        "name": "L字旅游签证",
        "eligible": "所有国家",
        "duration": "30-90天（单次/多次）",
        "how_to_apply": [
          "在中国驻外使领馆申请",
          "需提供护照原件、照片、往返机票、酒店预订",
          "部分国家可通过旅行社代办（省心）",
          "费用约¥700-1000（因国家而异）"
        ],
        "processing_time": "4-7个工作日",
        "tip": "建议提前1-2个月申请，旅游旺季可能更久"
      },
      "visa_free_hong_kong": {
        "name": "香港/澳门入境",
        "eligible": "大部分国家免签7-90天不等",
        "note": "香港和澳门的签证政策与中国大陆不同，通常更宽松",
        "tip": "从香港/澳门入境大陆仍需办理中国签证（除非符合144h过境条件）"
      },
      "apr_recommendations": [
        "⭐ 短期旅行(1-6天) → 144小时过境免签（省钱省时间）",
        "⭐ 专程度假 → 海南免签30天（海滩+免税购物）",
        "⭐ 探亲/深度游(7-30天) → L字旅游签证（申请需要时间）",
        "⭐ 同时游香港/澳门+大陆 → 先飞香港(免签)→再进大陆(144h免签)→香港出境"
      ],
      "important_notes": [
        "签证政策可能随时调整，出行前务必确认最新信息",
        "所有外国人在中国大陆必须随身携带护照原件",
        "住宿：酒店必须登记外国人信息（所有涉外酒店均可）",
        "高铁/飞机：外国人可以买票，建议提前网上购票（12306英文版）",
        "货币：微信/支付宝可绑定Visa/Mastercard，但需在入境后操作",
