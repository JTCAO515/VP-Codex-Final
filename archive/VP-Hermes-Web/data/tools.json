          "You must leave through a port in the same approved region"
        ],
        "how_to_apply": "Apply on arrival by filling out the temporary entry form at immigration"
      },
      "visa_free_hainan": {
        "name": "Hainan 30-Day Visa-Free Entry",
        "eligible": "Citizens of 59 eligible countries",
        "duration": "30 days",
        "conditions": [
          "Travel is limited to Hainan Province only",
          "You can enter through any of Hainan's open international ports"
        ],
        "note": "Best for travelers planning a dedicated beach or resort trip to Hainan"
      },
      "tourist_visa_l": {
        "name": "Tourist Visa (L Visa)",
        "eligible": "Available to all nationalities",
        "duration": "30-90 days, depending on single or multiple entry approval",
        "how_to_apply": [
          "Apply through a Chinese embassy or consulate in your country",
          "Prepare your passport, photo, round-trip flights, and hotel bookings",
          "In some countries, approved travel agencies can file the application for you",
          "Typical cost is around ¥700-1000, depending on nationality and location"
        ],
        "processing_time": "4-7 business days",
        "tip": "Apply 1-2 months early if possible, especially before peak travel seasons"
      },
      "visa_free_hong_kong": {
        "name": "Hong Kong / Macau Entry Rules",
        "eligible": "Most nationalities receive 7-90 days of visa-free access",
        "note": "Hong Kong and Macau follow separate immigration policies from mainland China, and the rules are usually more relaxed",
        "tip": "Entering mainland China from Hong Kong or Macau still requires a mainland visa unless you qualify for 144-hour transit"
      },
      "apr_recommendations": [
        "⭐ Short trip (1-6 days) → 144-hour visa-free transit is usually the fastest, cheapest option",
        "⭐ Hainan-only beach vacation → Use the 30-day Hainan visa-free policy",
        "⭐ Longer trip (7-30 days) → Apply for a Tourist L Visa in advance",
        "⭐ Hong Kong / Macau + mainland combo → Fly into Hong Kong first, then enter the mainland under the right transit or visa setup"
      ],
      "important_notes": [
        "Visa policies can change quickly, so always verify the latest rules before departure",
        "Foreign travelers in mainland China should carry the original passport at all times",
        "Hotels must register foreign guests, so choose hotels that can legally host overseas visitors",
        "Foreign travelers can book high-speed rail and domestic flights, and the 12306 English site is usually the easiest place to start",
        "WeChat Pay and Alipay can be linked to Visa or Mastercard, but setup usually works best after arrival",
        "A temporary SIM from China Unicom or China Mobile is often the easiest connectivity option",
        "Google, Instagram, and Facebook require a VPN in mainland China, so install and test one before you leave"
      ]
    }
