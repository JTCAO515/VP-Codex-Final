      "common_emergencies": {
        "lost_passport": {
          "title": "Lost Passport",
          "steps": [
            "1. Go to the nearest police station right away and get a written loss report",
            "2. Contact your embassy or consulate to apply for an Emergency Travel Document",
            "3. Ask the local exit-entry bureau about replacing or updating your visa status",
            "4. If you need to leave urgently, an emergency travel document may be enough for departure"
          ],
          "tip": "Keep a passport photocopy or phone scan with you — it helps a lot if the original is lost"
        },
        "medical_emergency": {
          "title": "Medical Emergency",
          "steps": [
            "1. Call 120 for an ambulance",
            "2. Tell the operator where you are and what symptoms you have",
            "3. Large hospitals often have international or foreign-patient clinics",
            "4. Bring your passport to the emergency desk — treatment usually comes first, billing after",
            "5. Contact your travel insurance provider as soon as possible"
          ],
          "tip": "Large hospitals in Beijing, Shanghai, and Guangzhou usually offer better English-language support"
        },
        "arrested": {
          "title": "Arrested / Detained",
          "steps": [
            "1. Ask the police to notify your embassy or consulate immediately",
            "2. Do not sign Chinese documents you do not understand",
            "3. Ask for an interpreter — one should be provided for legal proceedings",
            "4. Contact your travel insurer and any available legal support"
          ],
          "tip": "Foreign travelers are fully subject to Chinese law, so document every step and ask for interpretation support"
        },
        "natural_disaster": {
          "title": "Natural Disaster",
          "steps": [
            "1. Follow instructions from local authorities and venue staff",
            "2. Monitor official weather or earthquake alerts",
            "3. Tell your embassy or consulate where you are",
            "4. Keep your phone charged and use offline maps when possible"
          ],
          "tip": "Typhoons, flooding, and earthquakes are the most realistic risks depending on region and season, so check forecasts early"
        }
      },
