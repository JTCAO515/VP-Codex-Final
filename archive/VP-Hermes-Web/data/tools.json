    "desc": "Visa types, requirements, application process",
    "data": {
      "visa_free_transit_144h": {
        "name": "144-hour Visa-Free Transit",
        "eligible": "Citizens of 53 eligible countries, including the US, UK, France, Germany, Australia, Japan, and South Korea",
