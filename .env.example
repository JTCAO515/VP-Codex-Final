# China Travel Agent - Environment Variables
# Copy this file to .env and fill in your values

# JWT Configuration
JWT_SECRET_KEY=change-this-to-a-random-secret-string
JWT_EXPIRE_MINUTES=1440

# LLM (OpenAI Compatible) - Optional
LLM_ENABLED=0
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Google OAuth - Required for Google Sign-In
# Get your credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Vercel (production only)
# VERCEL=1
